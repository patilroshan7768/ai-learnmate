{
  "expo": {
    "name": "AI LearnMate",
    "slug": "ai-learnmate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F0F4FF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.ailearnmate"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F0F4FF"
      },
      "package": "com.yourname.ailearnmate"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-document-picker"
    ],
    "extra": {
      "eas": {
        "projectId": "b8bb6785-5943-4842-9254-6e2804ec5e2e"
      }
    }
  }
}
